{
  "name": "jblog",
  "version": "1.3.0",
  "scripts": {
    "dev": "concurrently 'bun run --hot src/index.ts' 'vite'",
    "build": "vite build",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:studio": "bunx drizzle-kit studio",
    "db:seed": "bun run src/db/seed.ts",
    "db:migrate:prod": "bun run src/db/migrate.ts",
    "deploy": "~/.fly/bin/flyctl deploy --config fly.toml",
    "deploy:open": "~/.fly/bin/flyctl apps open --app destellos-de-fe",
    "deploy:staging": "~/.fly/bin/flyctl deploy --config fly.staging.toml",
    "deploy:staging:open": "~/.fly/bin/flyctl apps open --app destellos-de-fe-staging",
    "logs": "~/.fly/bin/flyctl logs --app destellos-de-fe",
    "logs:staging": "~/.fly/bin/flyctl logs --app destellos-de-fe-staging"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@hono/oauth-providers": "^0.8.5",
    "@hono/zod-validator": "^0.7.6",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-query-devtools": "^5.99.2",
    "@tanstack/react-router": "^1.168.23",
    "@tiptap/extension-character-count": "^3.22.4",
    "@tiptap/extension-code-block-lowlight": "^3.22.4",
    "@tiptap/extension-highlight": "^3.22.4",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/extension-text-align": "^3.22.4",
    "@tiptap/extension-underline": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@types/marked": "^6.0.0",
    "arctic": "^3.7.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "hono": "^4.12.14",
    "hono-sessions": "^0.8.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.8.0",
    "marked": "^18.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "slugify": "^1.6.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.3",
    "@tanstack/router-devtools": "^1.166.13",
    "@tanstack/router-vite-plugin": "^1.166.37",
    "@types/bun": "^1.3.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.9"
  }
}
