{
  "name": "jblog",
  "scripts": {
    "dev": "concurrently --names 'server,css,client' --prefix-colors 'blue,green,yellow' 'bun run --hot src/index.ts' 'bunx tailwindcss -i src/styles/app.css -o public/styles.css --watch' 'bun build src/client/editor.tsx --outdir public/js/ --watch'",
    "dev:server": "bun run --hot src/index.ts",
    "dev:css": "bunx tailwindcss -i src/styles/app.css -o public/styles.css --watch",
    "dev:client": "bun build src/client/editor.tsx --outdir public/js/ --watch",
    "build": "bunx tailwindcss -i src/styles/app.css -o public/styles.css --minify && bun build src/client/editor.tsx --outdir public/js/ --minify",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:studio": "bunx drizzle-kit studio",
    "db:seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@hono/oauth-providers": "^0.8.5",
    "@hono/react-renderer": "^1.0.1",
    "@tiptap/extension-character-count": "^3.22.4",
    "@tiptap/extension-code-block-lowlight": "^3.22.4",
    "@tiptap/extension-highlight": "^3.22.4",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/extension-text-align": "^3.22.4",
    "@tiptap/extension-underline": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "arctic": "^3.7.0",
    "dompurify": "^3.4.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "hono": "^4.12.14",
    "hono-sessions": "^0.8.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "slugify": "^1.6.9"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bun": "latest",
    "@types/dompurify": "^3.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2"
  }
}
