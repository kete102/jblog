# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# Session secret (generate a long random string)
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Database
# Dev: leave empty to use local SQLite file
DATABASE_URL=./jblog.db
# Prod: set this to your PostgreSQL connection string
# DATABASE_URL=postgresql://user:password@host:5432/jblog

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Admin: the Google account email that gets auto-promoted to admin on first sign-in
ADMIN_EMAIL=your-admin@gmail.com

# S3 / Cloudflare R2 storage
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_BUCKET=jblog-media
S3_REGION=auto
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_PUBLIC_URL=https://media.yourdomain.com
